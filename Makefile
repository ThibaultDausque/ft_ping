CC = cc
NAME = ft_ping
CFLAGS = -Wall -Wextra -Werror -g
INCLUDE = -Iincludes
DIR = obj
SRC = src/main.c \
	  src/utils.c \
	  src/ft_ping.c

define HEADER
                ...+++++++++++-..          
.......   ...+++++++++++###+++++++##..     
.++++###..+++++++++##+#####+##########-.   
.+++###++++++++++++#--...###############.  
.####++++++#+######++#...+#############--  
.####++++######---#+##+##########..        
.#++++++####-.....-#+#+########..          
.+-.######-........-+##########+++#..      
.+...#+##-.........-+###########+++++#.    
.+...###-.......#..-############++++++++   
.+..+#+#.......##..+###############..+++#  
 .-..##........##.-##############....-+++-.
.###.#.........+-.#---+########-...--#####.
.######.-.......-......-######...-...  ....
   .----............+-.-#..-#-..-.         
   ..----.........-..--#........--.        
     ..-----.....----###.-+-......-.       
        ...++--+#######+...-.....-+#.      
     ..--------.+++#.-#-....----..+##      
    ..--........--++-...-.......-####..    
   ..-..........---++.-..-.---.+#####..    
   ..-..........---++-.-+++##.    .##..    
   .---........----+++-#######             
endef

OBJ = $(SRC:src/%.c=$(DIR)/%.o)

all: $(NAME)

export HEADER

$(NAME): $(OBJ)
	@$(CC) $(CFLAGS) $(INCLUDE) $(OBJ) -o $(NAME)
	@echo "$$HEADER"

$(DIR)/%.o: src/%.c
	@mkdir -p $(DIR)
	@$(CC) $(CFLAGS) $(INCLUDE) -c $< -o $@

clean:
	@rm -rf $(DIR)

fclean: clean
	@rm $(NAME)

re: fclean all

.PHONY: clean fclean all


